APP_ENV=prod
APP_NAME=Hebrew Transcription API

# Core
DB_URL=sqlite:///./data/app.db
# Optional secret file variant:
# DB_URL_FILE=/run/secrets/db_url
PRIMARY_MODEL_ID=ivrit-ai/whisper-large-v3
TOKEN_TTL_HOURS=12
TOKEN_HASH_PEPPER=
# Optional secret file variant:
# TOKEN_HASH_PEPPER_FILE=/run/secrets/token_hash_pepper

# Database pooling (for PostgreSQL)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Node identity (multi-node worker fleets)
NODE_ID=node-local
ENABLE_POSTGRES_SKIP_LOCKED=true

# ASR performance tuning
ASR_CHUNK_LENGTH_SEC=30
ASR_BATCH_SIZE_CPU=1
ASR_BATCH_SIZE_GPU=8
ASR_WARMUP_ENABLED=false

# Autoscale policy
AUTOSCALE_TARGET_QUEUE_PER_WORKER=2
AUTOSCALE_SCALE_UP_COOLDOWN_SECONDS=10
AUTOSCALE_SCALE_DOWN_COOLDOWN_SECONDS=20
AUTOSCALE_MAX_WORKERS_PER_NODE=8

# Cost control model
ESTIMATED_COST_PER_AUDIO_MINUTE=0.0
ESTIMATED_COST_CURRENCY=USD

# API security
CORS_ALLOWED_ORIGINS=http://localhost:8080
SECURITY_HEADERS_ENABLED=true
ENFORCE_HTTPS=false

# Rate limit
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=180
RATE_LIMIT_AUTH_MAX_REQUESTS=20

# Worker/resource
WORKER_POLL_SECONDS=2
WORKER_IDLE_SLEEP_SECONDS=1
WORKER_HEARTBEAT_SECONDS=5
WORKER_ONLINE_GRACE_SECONDS=15
MAX_PARALLEL_WORKERS_CPU=2
MAX_PARALLEL_WORKERS_GPU=2
CPU_SOFT_LIMIT_PERCENT=80
RAM_SOFT_LIMIT_PERCENT=80

# Retry
JOB_DEFAULT_MAX_RETRIES=2
JOB_RETRY_BACKOFF_SECONDS=30

# Ingestion
ALLOWED_EXTENSIONS=.wav,.mp3
